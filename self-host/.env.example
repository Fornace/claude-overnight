# Copy to .env — loaded by docker compose and passed into the runner.

# Anthropic-compatible provider. Any endpoint speaking the Anthropic Messages
# protocol works (Anthropic direct, OpenRouter, Kimi, DashScope, a local proxy).
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default models — overridable per run via --eval-model / --mutate-model.
EVAL_MODEL=claude-haiku-4-5
# MUTATE_MODEL=claude-sonnet-4-6

# Optional: pin the CLI version (default: latest from npm).
# CLAUDE_OVERNIGHT_VERSION=1.52.0

# Optional: change the host port for the HTTP server.
# SELF_HOST_PORT=8787

# Optional: token required on the HTTP server (omit to disable auth — only
# safe on a private network). When set, clients must send it as
# `Authorization: Bearer <token>`.
# SELF_HOST_TOKEN=
